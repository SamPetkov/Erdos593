import Erdos593.Graph.NonInducedFactor

/-!
# Finite non-induced factors generated by selected host edges

This module gives a deliberately local graph-theoretic construction.  A finite
set of edges of an ambient graph determines a finite endpoint type and a graph
on that type whose adjacencies map into the ambient graph.  It is intended as
finite infrastructure for the base-fibre reconstruction plan; it makes no
claim that an arbitrary selected edge set has already been reconstructed as a
triple-system expansion.
-/

namespace Erdos593

open scoped Sym2

universe u

noncomputable section

variable {V : Type u} (G : _root_.SimpleGraph V)

/-- The finite set of endpoints occurring in a finite selected set of host
edges. -/
def finiteEdgeEndpointFinset (A : Set G.edgeSet) (hA : A.Finite) : Finset V := by
  classical
  exact hA.toFinset.biUnion fun e => (e.1 : Sym2 V).toFinset

/-- The finite vertex type supporting a selected finite set of host edges. -/
abbrev finiteEdgeEndpointType (A : Set G.edgeSet) (hA : A.Finite) : Type u :=
  ↑(finiteEdgeEndpointFinset G A hA)

/-- Every endpoint of a selected edge belongs to the finite endpoint support. -/
theorem mem_finiteEdgeEndpointFinset {A : Set G.edgeSet} (hA : A.Finite)
    {e : G.edgeSet} (he : e ∈ A) {v : V} (hv : v ∈ (e.1 : Sym2 V)) :
    v ∈ finiteEdgeEndpointFinset G A hA := by
  classical
  simp only [finiteEdgeEndpointFinset, Finset.mem_biUnion]
  exact ⟨e, (hA.mem_toFinset).mpr he, Sym2.mem_toFinset.mpr hv⟩

/-- The graph on the finite endpoint support induced by the selected host
edges, with only the non-induced factor direction recorded. -/
def finiteEdgeFactorGraph (A : Set G.edgeSet) (hA : A.Finite) :
    _root_.SimpleGraph (finiteEdgeEndpointType G A hA) :=
  _root_.SimpleGraph.fromEdgeSet
    {a | Sym2.map Subtype.val a ∈ Subtype.val '' A}

/-- The canonical non-induced factor from the selected finite-edge graph to
the ambient graph. -/
def finiteEdgeFactor (A : Set G.edgeSet) (hA : A.Finite) :
    Erdos593.SimpleGraph.NonInducedFactor (finiteEdgeFactorGraph G A hA) G where
  vertex := Function.Embedding.subtype _
  map_adj := by
    intro x y hxy
    rw [finiteEdgeFactorGraph] at hxy
    rcases (_root_.SimpleGraph.fromEdgeSet_adj _).mp hxy with ⟨hxy, _⟩
    rcases hxy with ⟨e, heA, heq⟩
    apply G.mem_edgeSet.mp
    change s(x.1, y.1) ∈ G.edgeSet
    have hmap : Sym2.map Subtype.val s(x, y) = s(x.1, y.1) := by
      exact Sym2.map_mk Subtype.val x y
    rw [← hmap, ← heq]
    exact e.property

/-- A finite selected edge set yields a finite graph and a non-induced factor
into the host graph.  `Nonempty` is necessary because
`SimpleGraph.NonInducedFactor J G` is Type-valued. -/
theorem exists_finiteEdgeFactor (A : Set G.edgeSet) (hA : A.Finite) :
    let X := finiteEdgeEndpointType G A hA
    ∃ (_ : Fintype X) (J : _root_.SimpleGraph X),
      Nonempty (Erdos593.SimpleGraph.NonInducedFactor J G) := by
  dsimp only
  exact ⟨inferInstance, finiteEdgeFactorGraph G A hA,
    ⟨finiteEdgeFactor G A hA⟩⟩

end

end Erdos593
