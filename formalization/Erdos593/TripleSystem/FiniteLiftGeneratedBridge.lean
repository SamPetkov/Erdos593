import Erdos593.TripleSystem.FiniteLiftGenerated
import Erdos593.TripleSystem.DisjointUnionForward
import Erdos593.TripleSystem.ExpansionIntrinsic
import Erdos593.TripleSystem.IsomorphIntrinsic
import Erdos593.TripleSystem.OnePointAmalgamationIntrinsic

/-!
# Bridge closure for finite lift generation

Every system generated by finite private-vertex-expansion atoms has an
incident Levi bridge at every hyperedge.
-/

namespace Erdos593

universe u w

namespace TripleSystem

variable {V : Type u} (G : _root_.SimpleGraph V)

namespace FiniteLiftGenerated

theorem bridgeAtEveryEdge
    {X I : Type w} {K : TripleSystem X I}
    (hK : FiniteLiftGenerated G K) :
    K.BridgeAtEveryEdge := by
  induction hK with
  | ofEdgeless X =>
      exact (edgeless_intrinsic X).2.1
  | ofFactorExpansion f =>
      exact privateVertexExpansion_bridgeAtEveryEdge _
  | disjointUnion hF hH ihF ihH =>
      exact disjointUnion_bridgeAtEveryEdge _ _ ihF ihH
  | amalgam hF hH x y ihF ihH =>
      exact OnePointAmalgamation.amalgam_bridgeAtEveryEdge _ _ x y ihF ihH
  | ofIso hF f ihF =>
      exact (f.bridgeAtEveryEdge_iff).mp ihF

end FiniteLiftGenerated

end TripleSystem

end Erdos593
