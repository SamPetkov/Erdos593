import Erdos593.TripleSystem.SequenceLiftBaseApex

/-!
# Graph factors generated by canonical base letters

A selected set of canonical base letters determines an exact subgraph of the
host graph. This module supplies only that graph-side construction and its
finite-carrier and selected-edge interfaces; it does not assert an expansion
isomorphism for a sequence-lift fibre.
-/

namespace Erdos593

universe u

namespace SequenceLift

variable {V : Type u} (G : _root_.SimpleGraph V)

/-- The host subgraph whose edges are exactly a selected set of canonical
base letters. -/
noncomputable def baseLetterSubgraph (A : Set (Alphabet G)) : G.Subgraph :=
  { verts := {x : V | ∃ a : Alphabet G, a ∈ A ∧ x ∈ (a.1 : Sym2 V)}
    Adj := fun x y => s(x, y) ∈ ((fun a : Alphabet G => a.1) '' A)
    adj_sub := by
      intro v w h
      rcases h with ⟨a, ha, hEq⟩
      rw [← G.mem_edgeSet, ← hEq]
      exact a.property
    edge_vert := by
      intro v w h
      rcases h with ⟨a, ha, hEq⟩
      exact ⟨a, ha, by simp [hEq]⟩
    symm := ⟨by
      intro v w h
      rcases h with ⟨a, ha, hEq⟩
      refine ⟨a, ha, ?_⟩
      rw [hEq]
      exact Sym2.eq_swap⟩ }

/-- Coercing the selected-base-letter subgraph to its vertex subtype preserves
the selected host-edge set exactly. -/
theorem baseLetterSubgraph_edgeSet (A : Set (Alphabet G)) :
    (baseLetterSubgraph G A).edgeSet = ((fun a : Alphabet G => a.1) '' A) := by
  ext z
  induction z using Sym2.ind with
  | h x y => rfl

/-- A finite selected base-letter set has finite endpoint support. -/
theorem baseLetterSubgraph_finite_verts
    {A : Set (Alphabet G)} (hA : A.Finite) :
    (baseLetterSubgraph G A).verts.Finite := by
  classical
  rw [show (baseLetterSubgraph G A).verts =
      ⋃ a ∈ A, {x : V | x ∈ (a.1 : Sym2 V)} by
    ext x
    simp [baseLetterSubgraph]]
  apply hA.biUnion
  intro a ha
  rw [show ({x : V | x ∈ (a.1 : Sym2 V)}) = ↑a.1.toFinset by
    ext x
    simp]
  exact Finset.finite_toSet _

/-- The edges of the selected-base-letter factor are canonically equivalent
to the selected letters themselves. -/
noncomputable def baseLetterSubgraphEdgeEquiv (A : Set (Alphabet G)) :
    (baseLetterSubgraph G A).coe.edgeSet ≃ A := by
  let K := baseLetterSubgraph G A
  let f : K.coe.edgeSet → A := fun j =>
    let hjK : Sym2.map (fun x : K.verts => (x : V)) j.1 ∈ K.edgeSet := by
      simpa [SimpleGraph.Subgraph.edgeSet_coe] using j.2
    let e0 : Alphabet G :=
      ⟨Sym2.map (fun x : K.verts => (x : V)) j.1, K.edgeSet_subset hjK⟩
    ⟨e0, by
      rw [baseLetterSubgraph_edgeSet] at hjK
      rcases hjK with ⟨a, ha, hEq⟩
      rw [show e0 = a by
        apply Subtype.ext
        exact hEq.symm]
      exact ha⟩
  exact Equiv.ofBijective f (by
    constructor
    · intro j k hjk
      apply Subtype.ext
      apply Sym2.map.injective Subtype.val_injective
      simpa [f] using congrArg (fun a : A => a.1.1) hjk
    · intro a
      have hK : a.1.1 ∈ K.edgeSet := by
        rw [baseLetterSubgraph_edgeSet]
        exact ⟨a.1, a.2, rfl⟩
      rw [← SimpleGraph.Subgraph.image_coe_edgeSet_coe K] at hK
      rcases hK with ⟨j, hj, hmap⟩
      refine ⟨⟨j, hj⟩, ?_⟩
      apply Subtype.ext
      apply Subtype.ext
      simpa [f] using hmap)

end SequenceLift
end Erdos593
