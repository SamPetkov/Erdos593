/-- The balanced complete bipartite graph `K_{n,n}`, with both parts in
universe `u`. -/
abbrev completeBipartiteNN (n : ℕ) :
    _root_.SimpleGraph
      (FiniteBipartitePart.{u} n ⊕ FiniteBipartitePart.{u} n) :=
  _root_.completeBipartiteGraph
