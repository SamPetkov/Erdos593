        baseFiberSupportOverlapGraph_adj_iff.mpr ⟨hquNe, hqu⟩
      have hqvAdj : (baseFiberSupportOverlapGraph S).Adj q v' :=
        baseFiberSupportOverlapGraph_adj_iff.mpr ⟨hqvNe, hqv⟩
