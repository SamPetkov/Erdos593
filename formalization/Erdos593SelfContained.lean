namespace Erdos593

universe u

namespace SequenceLift

variable {V : Type u} (G : _root_.SimpleGraph V)

/-- The host subgraph whose edges are exactly a selected set of canonical
base letters. -/
noncomputable def baseLetterSubgraph (A : Set (Alphabet G)) : G.Subgraph :=
  { verts := {x : V | ∃ a : Alphabet G, a ∈ A ∧ x ∈ (a.1 : Sym2 V)}
    Adj := fun x y => s(x, y) ∈ ((fun a : Alphabet G => a.1) '' A)
    adj_sub := by
      intro v w h
      rcases h with ⟨a, ha, hEq⟩
      rw [← G.mem_edgeSet, ← hEq]
      exact a.property
    edge_vert := by
      intro v w h
      rcases h with ⟨a, ha, hEq⟩
      exact ⟨a, ha, by simp [hEq]⟩
    symm := ⟨by
      intro v w h
      rcases h with ⟨a, ha, hEq⟩
      refine ⟨a, ha, ?_⟩
      rw [hEq]
      exact Sym2.eq_swap⟩ }

