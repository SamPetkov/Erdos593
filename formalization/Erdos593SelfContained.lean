    {S : Set (Edge G)}
    (hlin : ((system G).edgeRestriction S).Linear) :
    Set.InjOn traceKey S := by
  intro e₁ hmem₁ e₂ hmem₂ hkey
  exact eq_of_traceKey_eq_of_mem_of_linear hlin hmem₁ hmem₂ hkey

