    intro e d h
    apply Subtype.ext
    apply F.simple
    ext x
    constructor
    · intro hxe
      let x' : F.EdgeSupport S := ⟨x, e.1, e.2, hxe⟩
      have hx := Set.ext_iff.mp h x'
      exact hx.mp hxe
    · intro hxd
      let x' : F.EdgeSupport S := ⟨x, d.1, d.2, hxd⟩
      have hx := Set.ext_iff.mp h x'
      exact hx.mpr hxd

