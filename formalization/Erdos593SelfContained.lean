    {hxy₁ : G.Adj x₁ y₁} {hxy₂ : G.Adj x₂ y₂}
    {hext₁ : q.ExtendsBy (edgeLetter hxy₁) t₁}
    {hext₂ : q.ExtendsBy (edgeLetter hxy₂) t₂}
    (heq :
      mkEdge q t₁ x₁ y₁ z₁ hxy₁ hext₁ =
