  ext z
  constructor
  · rintro ⟨⟨ζ, rfl⟩, hζ⟩
    let ξ : p.length.ToType :=
      Ordinal.ToType.mk ⟨(ζ.toOrd : Ordinal), hζ⟩
    refine ⟨ξ, ?_⟩
    apply Prod.ext
    · simp [ξ, Ordinal.ToType.toOrd]
    · have hnode := hseg.choose_spec ξ
      simpa [ξ, liftIndex, TracePrefix.restrictIndex] using hnode
