amalgamation. -/
theorem amalgam_evenBergeCycles
    (F₀ : TripleSystem V₀ E₀) (F₁ : TripleSystem V₁ E₁)
    (r₀ : V₀) (r₁ : V₁)
    (h₀ : F₀.EvenBergeCycles) (h₁ : F₁.EvenBergeCycles) :
