      rw [hletter]
      rw [← htu]
      exact hextq
    · rcases exists_mkEdge_at_baseNode e with ⟨t, x, y, z, hxy, hext, hem⟩
      rcases exists_mkEdge_at_baseNode f with ⟨v, w, r, s, hwr, hfext, hfm⟩
