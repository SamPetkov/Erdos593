    hacyclic.exists_tailAtMostOneNeighborOrder
  refine ⟨qs.map Subtype.val, hnodup.map Subtype.val_injective, ?_, ?_⟩
  · intro e he
    let q : activeBaseNodeIndex S := ⟨baseNode e, ⟨e, he, rfl⟩⟩
