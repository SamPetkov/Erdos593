    {S : Set (Edge G)} (q : Node G)
    (hlin : ((system G).edgeRestriction S).Linear) :
    (baseLetter '' baseFiber S q).Finite ↔ (baseFiber S q).Finite := by
  constructor
  · intro himage
    exact Set.Finite.of_finite_image himage
