BEGIN SOURCE MODULE: Erdos593.TripleSystem.BridgeBlockExpansion
Source: Erdos593/TripleSystem/BridgeBlockExpansion.lean
Normalized SHA-256: 71cc3aff8a6262d199c09f62b0b52be5b076379bd728d2ecd388ce3158e298c7
