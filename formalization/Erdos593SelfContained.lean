    e₁ = mkEdge (baseNode e₁) t₁ x₁ y₁ z₁ hxy₁ hext₁ := he₁
    _ = mkEdge (baseNode e₁) t₂ x₂ y₂ z₂ hxy₂ hext₂' :=
