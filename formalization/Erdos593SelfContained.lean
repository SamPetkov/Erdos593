the selected host-edge set exactly. -/
theorem baseLetterSubgraph_edgeSet (A : Set (Alphabet G)) :
    (baseLetterSubgraph G A).edgeSet = ((fun a : Alphabet G => a.1) '' A) := by
  ext z
  induction z using Sym2.ind with
  | h x y => rfl

