noncomputable def isoOfMaps {W : Type*} {D : Type*}
    (F₀ : TripleSystem V₀ E₀) (F₁ : TripleSystem V₁ E₁)
    (K : TripleSystem W D) (r₀ : V₀) (r₁ : V₁)
    (f₀ : V₀ → W) (f₁ : V₁ → W)
