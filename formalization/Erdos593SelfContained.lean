    {S : Set (Edge G)} (q : Node G)
    (hlinear : ((system G).edgeRestriction S).Linear) :
    Equiv (baseFiber S q) (baseApex '' baseFiber S q) :=
  Equiv.ofBijective
    (fun e =>
      Subtype.mk (baseApex e.val)
        (by
          exact Exists.intro e.val (And.intro e.property rfl)))
