    refine ⟨?_, Set.mem_setOf.mpr (Set.mem_Iio.mp ξ.toOrd.2)⟩
    refine ⟨liftIndex hseg.choose ξ, ?_⟩
    apply Prod.ext
    · exact (liftIndex_toOrd hseg.choose ξ).symm
    · exact (hseg.choose_spec ξ).symm

